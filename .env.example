# Core paths
SERVER_ROOT=/home/evgeny/pokerhub/PROD/server
FILES_DIR=/var/lib/fstracker

# App secrets
SECRET_KEY=change-me

# Postgres
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=firestorm
DB_PASSWORD=change-me
DB_USERS=users
DB_DASHBOARD=dashboard_data
DB_MIN_POOL=5
DB_MAX_POOL=20

# Upload limits
MAX_UPLOAD_SIZE_MB=200

# Rate limits
RATE_LIMIT_DEFAULT=180
RATE_LIMIT_LOGIN=30
RATE_LIMIT_UPLOAD=600
RATE_LIMIT_FILELIST=120

# ClamAV
CLAMAV_ENABLED=0
CLAMAV_CMD=
CLAMAV_TIMEOUT_SEC=30
QUARANTINE_DIR=/var/lib/fstracker_quarantine
QUARANTINE_ACTION=quarantine

# Redis queue (optional)
REDIS_ENABLED=0
REDIS_URL=redis://localhost:6379/0
REDIS_TTL_SEC=600
